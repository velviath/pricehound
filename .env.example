# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit it.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/pricehound

# JWT — generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-in-production

# OpenAI — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ScraperAPI — enables Amazon, eBay and bot-protected sites (optional but recommended)
# Free tier: 1000 req/month — sign up at scraperapi.com
SCRAPER_API_KEY=

# SMTP (Gmail example — use an App Password, not your main password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your@gmail.com

# Optional
PRICE_CHECK_INTERVAL_HOURS=4
APP_HOST=http://localhost:8000
